# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=betalent

# Payment Gateways (defaults usados quando não definidos: localhost)
# Em Docker, usar os hostnames dos containers
# GATEWAY1_URL=http://gateways:3001
# GATEWAY2_URL=http://gateways:3002
# Gateway auth (defaults to mock credentials if not set)
# GATEWAY1_AUTH_EMAIL=
# GATEWAY1_AUTH_TOKEN=
# GATEWAY2_AUTH_TOKEN=
# GATEWAY2_AUTH_SECRET=

# Admin seed
ADMIN_EMAIL=
ADMIN_PASSWORD=